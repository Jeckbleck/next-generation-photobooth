<Application x:Class="Photobooth.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Colour palette -->
            <SolidColorBrush x:Key="BackgroundBrush"    Color="#1A1A2E"/>
            <SolidColorBrush x:Key="AccentBrush"        Color="#E94560"/>
            <SolidColorBrush x:Key="AccentHoverBrush"   Color="#FF2040"/>
            <SolidColorBrush x:Key="AccentPressedBrush" Color="#C0304A"/>
            <SolidColorBrush x:Key="SurfaceBrush"       Color="#16213E"/>
            <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#FFFFFF"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A0A0C0"/>

            <!-- Base button style -->
            <Style x:Key="KioskButton" TargetType="Button">
                <Setter Property="Background"      Value="{DynamicResource AccentBrush}"/>
                <Setter Property="Foreground"      Value="White"/>
                <Setter Property="FontSize"        Value="22"/>
                <Setter Property="FontWeight"      Value="Bold"/>
                <Setter Property="Padding"         Value="40,16"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="{DynamicResource AccentPressedBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Ghost/secondary button -->
            <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource KioskButton}">
                <Setter Property="Background"     Value="Transparent"/>
                <Setter Property="Foreground"     Value="{StaticResource TextSecondaryBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush"    Value="{StaticResource TextSecondaryBrush}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
