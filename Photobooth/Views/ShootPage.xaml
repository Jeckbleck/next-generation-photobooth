<Page x:Class="Photobooth.Views.ShootPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:Photobooth.Views"
      Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── TOP BAR ───────────────────────────────────────────────────── -->
        <!-- BackgroundBrush rect behind a semi-transparent dark overlay      -->
        <Grid Grid.Row="0">
            <Border Background="{DynamicResource BackgroundBrush}"/>
            <Border Background="#66000000" Padding="20,14">
                <TextBlock x:Name="StatusText"
                           Text="Get ready!"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="20"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- ── EVF ROW ───────────────────────────────────────────────────── -->
        <!-- EVF fills the full row. Side buttons float over the edges.       -->
        <Grid Grid.Row="1">

            <!-- Live view feed — full frame visible, letterboxed against background.
                 Mirrored by default (RenderTransform below) so people can position
                 themselves naturally, like a mirror, while framing up before a shot;
                 flipped back to unmirrored while the just-captured photo is shown so
                 any text in frame reads correctly, matching the final printed strip. -->
            <Image x:Name="EvfImage"
                   Stretch="Uniform"
                   IsHitTestVisible="False"
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <ScaleTransform x:Name="EvfMirrorTransform" ScaleX="-1"/>
                </Image.RenderTransform>
            </Image>

            <!-- Loading spinner while waiting for photo download -->
            <local:LoadingSpinner x:Name="CaptureSpinner"
                                   Width="64" Height="64"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed"/>

            <!-- Cancel — left semi-circle (flat edge on left, curve opens right) -->
            <Button Width="130" Height="260"
                    HorizontalAlignment="Left" VerticalAlignment="Center"
                    BorderThickness="0" Cursor="Hand"
                    Click="Back_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                CornerRadius="0,130,130,0"
                                Background="{DynamicResource AccentBrush}">
                            <TextBlock Text="✕"
                                       FontSize="36" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AccentPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Retake — right semi-circle (curve opens left). Always visible; disabled until retake window. -->
            <Button x:Name="RetakeButton"
                    Width="130" Height="260"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    BorderThickness="0" Cursor="Hand"
                    IsEnabled="False"
                    Click="RetakeButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                CornerRadius="130,0,0,130"
                                Background="{DynamicResource AccentBrush}">
                            <TextBlock Text="↺"
                                       FontSize="36" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AccentPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.28"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- ── BOTTOM BAR ───────────────────────────────────────────────── -->
        <Grid Grid.Row="2">
            <Border Background="{DynamicResource BackgroundBrush}"/>
            <Border Background="#66000000" Padding="16,12">
                <StackPanel x:Name="ThumbnailBar"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- ── FULL-SCREEN OVERLAYS (span all rows) ─────────────────────── -->

        <!-- Countdown number -->
        <TextBlock x:Name="CountdownText"
                   Grid.RowSpan="3"
                   Visibility="Collapsed"
                   Foreground="White"
                   FontSize="200" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Opacity="0.85">
            <TextBlock.Effect>
                <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0"/>
            </TextBlock.Effect>
        </TextBlock>

        <!-- White flash on capture -->
        <Rectangle x:Name="FlashOverlay"
                   Grid.RowSpan="3"
                   Fill="White" Opacity="0"
                   IsHitTestVisible="False"/>

        <!-- Camera-disconnected modal -->
        <Grid x:Name="DisconnectOverlay"
              Grid.RowSpan="3"
              Visibility="Collapsed">
            <Rectangle Fill="#CC000000"/>
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="12" Width="440" Padding="40"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Camera Disconnected"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="26" FontWeight="Bold"
                               Margin="0,0,0,12"/>
                    <TextBlock Text="Your session was interrupted because the camera lost connection. Please check the USB cable and try again."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="15" TextWrapping="Wrap"
                               Margin="0,0,0,28"/>
                    <Button Content="← GO BACK"
                            Style="{StaticResource KioskButton}"
                            HorizontalAlignment="Left"
                            Padding="28,12" FontSize="16"
                            Click="Back_Click"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Page>
