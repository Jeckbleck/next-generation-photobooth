<Page x:Class="Photobooth.Views.ShootPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundBrush}">

    <Grid>
        <!-- Live view feed -->
        <Image x:Name="EvfImage"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>

        <!-- Status bar at top -->
        <Border VerticalAlignment="Top"
                Background="#80000000"
                Padding="24,12">
            <Grid>
                <TextBlock x:Name="StatusText"
                           Text="Get ready!"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="20"
                           HorizontalAlignment="Center"/>

                <!-- Photo indicators -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Ellipse x:Name="Dot1" Width="16" Height="16" Fill="#334" Margin="0,0,10,0"/>
                    <Ellipse x:Name="Dot2" Width="16" Height="16" Fill="#334" Margin="0,0,10,0"/>
                    <Ellipse x:Name="Dot3" Width="16" Height="16" Fill="#334"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Countdown overlay -->
        <TextBlock x:Name="CountdownText"
                   Visibility="Collapsed"
                   Foreground="White"
                   FontSize="200"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Opacity="0.85">
            <TextBlock.Effect>
                <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0"/>
            </TextBlock.Effect>
        </TextBlock>

        <!-- Flash overlay (white flash on capture) -->
        <Rectangle x:Name="FlashOverlay"
                   Fill="White"
                   Opacity="0"
                   IsHitTestVisible="False"/>

        <!-- Bottom bar -->
        <Border VerticalAlignment="Bottom"
                Background="#80000000"
                Padding="24,16">
            <Grid>
                <Button x:Name="StartButton"
                        Content="TAKE PHOTOS"
                        Style="{StaticResource KioskButton}"
                        HorizontalAlignment="Center"
                        Click="StartButton_Click"/>

                <Button Content="← Back"
                        Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Left"
                        Padding="20,10" FontSize="16"
                        Click="Back_Click"/>
            </Grid>
        </Border>
    </Grid>
</Page>
