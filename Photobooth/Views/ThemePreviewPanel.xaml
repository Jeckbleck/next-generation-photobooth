<UserControl x:Class="Photobooth.Views.ThemePreviewPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Preview"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="12" Margin="0,0,0,10"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── GREETING ─────────────────────────────── -->
            <StackPanel Grid.Column="0">
                <Border Height="160" CornerRadius="6" ClipToBounds="True"
                        BorderBrush="#2A3A5A" BorderThickness="1">
                    <Grid Background="{DynamicResource BackgroundBrush}">

                        <!-- Centered greeting content -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Width="75">
                            <!-- Eyebrow text -->
                            <Border Height="3" Width="36" CornerRadius="1.5"
                                    Background="White" Opacity="0.25"
                                    HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <!-- Title -->
                            <Border Height="7" CornerRadius="2"
                                    Background="White" Opacity="0.65"
                                    Margin="0,0,0,3"/>
                            <!-- Accent divider -->
                            <Border Height="2" Width="44" CornerRadius="1"
                                    Background="{DynamicResource AccentBrush}"
                                    HorizontalAlignment="Center" Margin="0,4,0,4"/>
                            <!-- Subtitle lines -->
                            <Border Height="3" CornerRadius="1.5"
                                    Background="White" Opacity="0.25"
                                    Margin="0,0,0,3"/>
                            <Border Height="3" Width="56" CornerRadius="1.5"
                                    Background="White" Opacity="0.25"
                                    HorizontalAlignment="Center" Margin="0,0,0,14"/>
                            <!-- CTA button -->
                            <Border Height="16" CornerRadius="4"
                                    Background="{DynamicResource AccentBrush}"/>
                        </StackPanel>

                        <!-- Settings gear dot (bottom-right) -->
                        <Ellipse Width="8" Height="8"
                                 Fill="White" Opacity="0.2"
                                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                 Margin="0,0,8,8"/>
                    </Grid>
                </Border>
                <TextBlock Text="Greeting" FontSize="10"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- ── SHOOT ─────────────────────────────────── -->
            <StackPanel Grid.Column="2">
                <Border Height="160" CornerRadius="6" ClipToBounds="True"
                        BorderBrush="#2A3A5A" BorderThickness="1">
                    <Grid Background="{DynamicResource BackgroundBrush}">

                        <!-- Top HUD bar: #80000000 overlay (hardcoded, not theme) -->
                        <Border VerticalAlignment="Top" Height="26"
                                Background="#80000000">
                            <Grid Margin="8,0">
                                <!-- ✕ button mock -->
                                <Border Width="10" Height="10"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Background="White" Opacity="0.6"
                                        CornerRadius="5"/>
                                <!-- Status text mock -->
                                <Border Height="4" Width="36" CornerRadius="2"
                                        Background="White" Opacity="0.5"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                <!-- Progress dots: hardcoded #334 in real page -->
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center">
                                    <Ellipse Width="5" Height="5" Fill="#334" Margin="2,0"/>
                                    <Ellipse Width="5" Height="5" Fill="#334" Margin="2,0"/>
                                    <Ellipse Width="5" Height="5" Fill="#334"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Bottom bar: #80000000 overlay with thumbnail slots -->
                        <Border VerticalAlignment="Bottom" Height="56"
                                Background="#80000000">
                            <!-- 3 thumbnail slots centred — #1A2B44 hardcoded in real page -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Border Width="26" Height="40" CornerRadius="3"
                                        Background="#1A2B44" Margin="0,0,5,0"/>
                                <Border Width="26" Height="40" CornerRadius="3"
                                        Background="#1A2B44" Margin="0,0,5,0"/>
                                <Border Width="26" Height="40" CornerRadius="3"
                                        Background="#1A2B44"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
                <TextBlock Text="Shoot" FontSize="10"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- ── RESULTS ────────────────────────────────── -->
            <StackPanel Grid.Column="4">
                <Border Height="160" CornerRadius="6" ClipToBounds="True"
                        BorderBrush="#2A3A5A" BorderThickness="1">
                    <Grid Background="{DynamicResource BackgroundBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="13"/>
                            <RowDefinition Height="26"/>
                        </Grid.RowDefinitions>

                        <!-- Title + AccentBrush underline -->
                        <StackPanel Grid.Row="0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <Border Height="5" Width="48" CornerRadius="2"
                                    Background="White" Opacity="0.65"/>
                            <Border Height="2" Width="28" CornerRadius="1"
                                    Background="{DynamicResource AccentBrush}"
                                    HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Layered tilted photo strips -->
                        <Grid Grid.Row="1"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                            <!-- Back copy: tilted left, faded -->
                            <Border Width="24" Height="54" CornerRadius="2"
                                    Background="White" Opacity="0.35"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <TransformGroup>
                                        <RotateTransform Angle="-7"/>
                                        <TranslateTransform X="-9" Y="5"/>
                                    </TransformGroup>
                                </Border.RenderTransform>
                            </Border>
                            <!-- Front copy: slight right tilt, prominent -->
                            <Border Width="24" Height="54" CornerRadius="2"
                                    Background="White" Opacity="0.82"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <TransformGroup>
                                        <RotateTransform Angle="5"/>
                                        <TranslateTransform X="7" Y="0"/>
                                    </TransformGroup>
                                </Border.RenderTransform>
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="2" BlurRadius="5"
                                                      Color="Black" Opacity="0.40"/>
                                </Border.Effect>
                            </Border>
                        </Grid>

                        <!-- NavBrush AI status bar -->
                        <Border Grid.Row="2" Background="{DynamicResource NavBrush}"
                                Margin="8,1" CornerRadius="2"/>

                        <!-- Two AccentBrush buttons: PRINT (left) · START AGAIN (right) -->
                        <Grid Grid.Row="3" Margin="8,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Background="{DynamicResource AccentBrush}"
                                    CornerRadius="3"/>
                            <Border Grid.Column="2"
                                    Background="{DynamicResource AccentBrush}"
                                    CornerRadius="3"/>
                        </Grid>
                    </Grid>
                </Border>
                <TextBlock Text="Results" FontSize="10"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

        </Grid>
    </StackPanel>
</UserControl>
