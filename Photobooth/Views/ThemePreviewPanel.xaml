<UserControl x:Class="Photobooth.Views.ThemePreviewPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Preview"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="12" Margin="0,0,0,10"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── GREETING ─────────────────────────────── -->
            <StackPanel Grid.Column="0">
                <Border Height="160" CornerRadius="6" ClipToBounds="True"
                        BorderBrush="#2A3A5A" BorderThickness="1">
                    <Grid Background="{DynamicResource BackgroundBrush}">

                        <!-- Centered greeting content -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Width="75">
                            <!-- Eyebrow (secondary text color) -->
                            <Border Height="3" Width="36" CornerRadius="1.5"
                                    Background="{DynamicResource TextSecondaryBrush}" Opacity="0.5"
                                    HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <!-- Title (primary text color) -->
                            <Border Height="7" CornerRadius="2"
                                    Background="{DynamicResource TextPrimaryBrush}" Opacity="0.85"
                                    Margin="0,0,0,3"/>
                            <!-- Accent divider -->
                            <Border Height="2" Width="44" CornerRadius="1"
                                    Background="{DynamicResource AccentBrush}"
                                    HorizontalAlignment="Center" Margin="0,4,0,4"/>
                            <!-- Subtitle lines (secondary text color) -->
                            <Border Height="3" CornerRadius="1.5"
                                    Background="{DynamicResource TextSecondaryBrush}" Opacity="0.5"
                                    Margin="0,0,0,3"/>
                            <Border Height="3" Width="56" CornerRadius="1.5"
                                    Background="{DynamicResource TextSecondaryBrush}" Opacity="0.5"
                                    HorizontalAlignment="Center" Margin="0,0,0,14"/>
                            <!-- CTA button -->
                            <Border Height="16" CornerRadius="4"
                                    Background="{DynamicResource AccentBrush}"/>
                        </StackPanel>

                        <!-- Settings gear dot (bottom-right) -->
                        <Ellipse Width="8" Height="8"
                                 Fill="White" Opacity="0.2"
                                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                 Margin="0,0,8,8"/>
                    </Grid>
                </Border>
                <TextBlock Text="Greeting" FontSize="10"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- ── SHOOT ─────────────────────────────────── -->
            <StackPanel Grid.Column="2">
                <Border Height="160" CornerRadius="6" ClipToBounds="True"
                        BorderBrush="#2A3A5A" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="26"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="42"/>
                        </Grid.RowDefinitions>

                        <!-- Top bar: BackgroundBrush + semi-transparent overlay + status text -->
                        <Grid Grid.Row="0">
                            <Border Background="{DynamicResource BackgroundBrush}"/>
                            <Border Background="#66000000">
                                <Border Height="4" Width="38" CornerRadius="2"
                                        Background="White" Opacity="0.55"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- EVF area: BackgroundBrush + left/right AccentBrush semi-circles -->
                        <Grid Grid.Row="1" Background="{DynamicResource BackgroundBrush}">
                            <!-- Cancel: left semi-circle -->
                            <Border Width="14" Height="46" CornerRadius="0,23,23,0"
                                    Background="{DynamicResource AccentBrush}"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <!-- Retake: right semi-circle (dimmed = starts disabled) -->
                            <Border Width="14" Height="46" CornerRadius="23,0,0,23"
                                    Background="{DynamicResource AccentBrush}" Opacity="0.28"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Bottom bar: BackgroundBrush + semi-transparent overlay + 3 thumbnail slots -->
                        <Grid Grid.Row="2">
                            <Border Background="{DynamicResource BackgroundBrush}"/>
                            <Border Background="#66000000">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <Border Width="24" Height="32" CornerRadius="3"
                                            Background="#1A2B44" Margin="0,0,5,0"/>
                                    <Border Width="24" Height="32" CornerRadius="3"
                                            Background="#1A2B44" Margin="0,0,5,0"/>
                                    <Border Width="24" Height="32" CornerRadius="3"
                                            Background="#1A2B44"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
                <TextBlock Text="Shoot" FontSize="10"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- ── RESULTS ────────────────────────────────── -->
            <StackPanel Grid.Column="4">
                <Border Height="160" CornerRadius="6" ClipToBounds="True"
                        BorderBrush="#2A3A5A" BorderThickness="1">
                    <Grid Background="{DynamicResource BackgroundBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="7"/>
                        </Grid.RowDefinitions>

                        <!-- Title + AccentBrush underline -->
                        <StackPanel Grid.Row="0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <Border Height="5" Width="48" CornerRadius="2"
                                    Background="{DynamicResource TextPrimaryBrush}" Opacity="0.65"/>
                            <Border Height="2" Width="28" CornerRadius="1"
                                    Background="{DynamicResource AccentBrush}"
                                    HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- 3-column: START AGAIN | photostrips | PRINT -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left: START AGAIN button pill -->
                            <Border Grid.Column="0" Height="12" CornerRadius="3"
                                    Background="{DynamicResource AccentBrush}"
                                    Margin="6,0" VerticalAlignment="Center"/>

                            <!-- Center: layered tilted photostrips -->
                            <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border Width="20" Height="46" CornerRadius="2"
                                        Background="White" Opacity="0.35"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <RotateTransform Angle="-7"/>
                                            <TranslateTransform X="-8" Y="4"/>
                                        </TransformGroup>
                                    </Border.RenderTransform>
                                </Border>
                                <Border Width="20" Height="46" CornerRadius="2"
                                        Background="White" Opacity="0.82"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <RotateTransform Angle="5"/>
                                            <TranslateTransform X="6" Y="0"/>
                                        </TransformGroup>
                                    </Border.RenderTransform>
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="2" BlurRadius="4"
                                                          Color="Black" Opacity="0.35"/>
                                    </Border.Effect>
                                </Border>
                            </Grid>

                            <!-- Right: PRINT button pill -->
                            <Border Grid.Column="2" Height="12" CornerRadius="3"
                                    Background="{DynamicResource AccentBrush}"
                                    Margin="6,0" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Countdown bar: thin AccentBrush strip at bottom -->
                        <Border Grid.Row="2" Background="{DynamicResource AccentBrush}"/>
                    </Grid>
                </Border>
                <TextBlock Text="Results" FontSize="10"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

        </Grid>
    </StackPanel>
</UserControl>
