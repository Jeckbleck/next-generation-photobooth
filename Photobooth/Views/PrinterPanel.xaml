<UserControl x:Class="Photobooth.Views.PrinterPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Printer" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" FontWeight="Bold" Margin="0,0,0,20"/>

        <TextBlock Text="CONNECTION" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
        <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

        <TextBlock x:Name="PrinterStatusText" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,8"/>
        <ComboBox x:Name="PrinterDropdown"
                  Width="320" HorizontalAlignment="Left"
                  Margin="0,0,0,4"
                  SelectionChanged="PrinterDropdown_SelectionChanged"/>
        <TextBlock Text="Select the printer to use for photo strips." Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,20"/>

        <TextBlock Text="PAPER" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
        <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="Paper size" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="Portrait 4×6  (auto)" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" VerticalAlignment="Center"/>
        </Grid>
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="Copies" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" Padding="8,6" Width="70" HorizontalAlignment="Left">
                <ComboBoxItem Content="1" IsSelected="True"/>
                <ComboBoxItem Content="2"/>
            </ComboBox>
        </Grid>

        <Border Background="#0D1B2A" CornerRadius="8" Padding="14,10" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠" Foreground="#E9A020" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Top"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                    Enable <Run FontWeight="Bold" Foreground="White">2-inch cut</Run> in the DNP driver once: Printer Properties → Advanced → Printing Defaults → Printer Features → 2 inch cut.
                </TextBlock>
            </StackPanel>
        </Border>

        <TextBlock Text="BEHAVIOUR" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
        <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Auto-print" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                <TextBlock Text="Print the strip automatically at the end of each session" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
            <ToggleButton x:Name="AutoPrintToggle" Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Click="AutoPrintToggle_Click"/>
        </Grid>
    </StackPanel>
</UserControl>
