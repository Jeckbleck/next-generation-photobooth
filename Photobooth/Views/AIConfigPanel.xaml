<UserControl x:Class="Photobooth.Views.AIConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="AI Enhancement" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" FontWeight="Bold" Margin="0,0,0,10"/>
        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" LineHeight="20" Margin="0,0,0,20">
            Enhance photos with AI-powered style processing via a local FastAPI server before printing and display. The server runs separately on this machine or on the local network.
        </TextBlock>

        <TextBlock Text="CONNECTION" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
        <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Enable AI Enhancement" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                <TextBlock Text="Show style picker before each session" Foreground="#445566" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
            <ToggleButton x:Name="AIEnableToggle" Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Click="AIEnableToggle_Click"/>
        </Grid>

        <TextBlock Text="Server URL" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,10,0,4"/>
        <TextBox x:Name="AIServerUrlBox" Background="#0D1B2A" Foreground="White" BorderBrush="#334" Padding="10,7" FontSize="13" Margin="0,0,0,8" LostFocus="AIServerUrl_LostFocus"/>

        <TextBlock Text="API Key" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="AIApiKeyBox" Background="#0D1B2A" Foreground="White" BorderBrush="#334" Padding="10,7" FontSize="13" Margin="0,0,0,12" LostFocus="AIApiKey_LostFocus"/>

        <Button Content="Test Connection" Click="TestAIConnection_Click"
                Style="{StaticResource GhostButton}" HorizontalAlignment="Left"
                Padding="12,6" FontSize="12" Margin="0,0,0,12"/>

        <StackPanel Orientation="Horizontal">
            <Ellipse x:Name="AIStatusDot" Width="8" Height="8" Fill="#555577" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock x:Name="AIStatusText" Text="Not tested" Foreground="#555577" FontSize="13"/>
        </StackPanel>
    </StackPanel>
</UserControl>
