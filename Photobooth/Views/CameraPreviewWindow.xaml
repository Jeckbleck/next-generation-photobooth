<Window x:Class="Photobooth.Views.CameraPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Live Preview"
        Width="860" Height="660"
        MinWidth="480" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="#0D1B2A"
        ResizeMode="CanResizeWithGrip">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Preview area -->
        <Border Grid.Row="0" Background="#000" Margin="12,12,12,8">
            <Grid>
                <Image x:Name="PreviewImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="LowQuality"/>
                <TextBlock x:Name="WaitingText"
                           Text="Starting live view…"
                           Foreground="#88FFFFFF"
                           FontSize="15"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="1" Background="#111827" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Foreground="#88FFFFFF"
                           FontSize="12"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Close"
                        Padding="18,7" FontSize="13"
                        Background="#334155" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="Close_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#475569"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
