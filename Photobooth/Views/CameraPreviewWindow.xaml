<Window x:Class="Photobooth.Views.CameraPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Live Preview"
        Width="860" Height="660"
        MinWidth="480" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource NavBrush}"
        ResizeMode="CanResizeWithGrip">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Preview area -->
        <Border Grid.Row="0" Background="#000" Margin="12,12,12,8">
            <Grid>
                <Image x:Name="PreviewImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="LowQuality"/>
                <TextBlock x:Name="WaitingText"
                           Text="Starting live view…"
                           Foreground="#88FFFFFF"
                           FontSize="15"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="1" Background="#111827" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Foreground="#88FFFFFF"
                           FontSize="12"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Close"
                        Style="{StaticResource GhostButton}"
                        Padding="18,7" FontSize="13"
                        Click="Close_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
