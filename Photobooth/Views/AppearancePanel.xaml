<UserControl x:Class="Photobooth.Views.AppearancePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="APPEARANCE" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
        <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

        <TextBlock Text="Greeting background" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="BgPathBox"
                     Background="#0D1B2A" Foreground="White" BorderBrush="#334"
                     Padding="10,7" FontSize="12" IsReadOnly="True"
                     VerticalContentAlignment="Center"/>
            <Button Grid.Column="1" Content="Browse"
                    Style="{StaticResource GhostButton}"
                    Padding="14,6" FontSize="13" Margin="8,0,0,0"
                    Click="BrowseGreetingBg_Click"/>
            <Button Grid.Column="2" Content="Clear"
                    Style="{StaticResource GhostButton}"
                    Padding="14,6" FontSize="13" Margin="6,0,0,0"
                    Click="ClearGreetingBg_Click"/>
        </Grid>
        <Border x:Name="BgPreviewBorder"
                Height="64" CornerRadius="6"
                Background="#0D1B2A" BorderBrush="#1E2F4A" BorderThickness="1"
                Margin="0,0,0,20" ClipToBounds="True"
                Visibility="Collapsed">
            <Image x:Name="BgPreviewImage" Stretch="UniformToFill"/>
        </Border>

        <TextBlock Text="Accent color" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
        <Button Width="34" Height="34" HorizontalAlignment="Left" Cursor="Hand"
                Margin="0,0,0,10" Click="PickAccentColor_Click" ToolTip="Click to pick accent color">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Width="34" Height="34" CornerRadius="6"
                            Background="{DynamicResource AccentBrush}"
                            BorderBrush="#555" BorderThickness="1"/>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <TextBlock Text="App background" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
        <Button Width="34" Height="34" HorizontalAlignment="Left" Cursor="Hand"
                Margin="0,0,0,10" Click="PickBgColor_Click" ToolTip="Click to pick background color">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Width="34" Height="34" CornerRadius="6"
                            Background="{DynamicResource BackgroundBrush}"
                            BorderBrush="#555" BorderThickness="1"/>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <TextBlock Text="Surface" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
        <Button Width="34" Height="34" HorizontalAlignment="Left" Cursor="Hand"
                Margin="0,0,0,20" Click="PickSurfaceColor_Click" ToolTip="Click to pick surface color">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Width="34" Height="34" CornerRadius="6"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="#555" BorderThickness="1"/>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Button Content="Revert to defaults"
                Style="{StaticResource GhostButton}"
                HorizontalAlignment="Right"
                Padding="14,6" FontSize="13"
                Margin="0,0,0,20"
                Click="RevertAppearance_Click"/>
    </StackPanel>
</UserControl>
