<UserControl x:Class="Photobooth.Views.AppearancePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="APPEARANCE" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
        <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

        <TextBlock Text="Greeting background" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="BgPathBox"
                     Background="{DynamicResource NavBrush}" Foreground="White" BorderBrush="#334"
                     Padding="10,7" FontSize="12" IsReadOnly="True"
                     VerticalContentAlignment="Center"/>
            <Button Grid.Column="1" Content="Browse"
                    Style="{StaticResource GhostButton}"
                    Padding="14,6" FontSize="13" Margin="8,0,0,0"
                    Click="BrowseGreetingBg_Click"/>
            <Button Grid.Column="2" Content="Clear"
                    Style="{StaticResource GhostButton}"
                    Padding="14,6" FontSize="13" Margin="6,0,0,0"
                    Click="ClearGreetingBg_Click"/>
        </Grid>
        <Border x:Name="BgPreviewBorder"
                Height="64" CornerRadius="6"
                Background="{DynamicResource NavBrush}" BorderBrush="#1E2F4A" BorderThickness="1"
                Margin="0,0,0,20" ClipToBounds="True"
                Visibility="Collapsed">
            <Image x:Name="BgPreviewImage" Stretch="UniformToFill"/>
        </Border>

        <TextBlock Text="Colors" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10"/>
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Accent -->
            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                <Button Width="56" Height="56" Cursor="Hand"
                        Click="PickAccentColor_Click" ToolTip="Accent color">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Width="56" Height="56" CornerRadius="10"
                                    Background="{DynamicResource AccentBrush}"
                                    BorderBrush="#555" BorderThickness="1.5"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock Text="Accent" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,7,0,0"/>
            </StackPanel>

            <!-- Background -->
            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                <Button Width="56" Height="56" Cursor="Hand"
                        Click="PickBgColor_Click" ToolTip="App background">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Width="56" Height="56" CornerRadius="10"
                                    Background="{DynamicResource BackgroundBrush}"
                                    BorderBrush="#555" BorderThickness="1.5"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock Text="Background" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,7,0,0"/>
            </StackPanel>

            <!-- Surface -->
            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                <Button Width="56" Height="56" Cursor="Hand"
                        Click="PickSurfaceColor_Click" ToolTip="Surface / panels">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Width="56" Height="56" CornerRadius="10"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="#555" BorderThickness="1.5"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock Text="Surface" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,7,0,0"/>
            </StackPanel>

            <!-- Navigation -->
            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                <Button Width="56" Height="56" Cursor="Hand"
                        Click="PickNavColor_Click" ToolTip="Navigation / input wells">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Width="56" Height="56" CornerRadius="10"
                                    Background="{DynamicResource NavBrush}"
                                    BorderBrush="#555" BorderThickness="1.5"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock Text="Navigation" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,7,0,0"/>
            </StackPanel>
        </Grid>

        <Button Content="Revert to defaults"
                Style="{StaticResource GhostButton}"
                HorizontalAlignment="Right"
                Padding="14,6" FontSize="13"
                Margin="0,0,0,20"
                Click="RevertAppearance_Click"/>
    </StackPanel>
</UserControl>
