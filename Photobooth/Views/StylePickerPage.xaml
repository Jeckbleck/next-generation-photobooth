<Page x:Class="Photobooth.Views.StylePickerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}">

    <Page.Resources>
        <Style x:Key="StyleCard" TargetType="ListBoxItem">
            <Setter Property="Padding"  Value="0"/>
            <Setter Property="Margin"   Value="10"/>
            <Setter Property="Cursor"   Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="CardBorder"
                                Width="230" Height="110"
                                CornerRadius="10"
                                Background="#0D1B2A"
                                BorderThickness="2"
                                BorderBrush="#1E2F4A"
                                Padding="18,14">
                            <StackPanel>
                                <TextBlock x:Name="CardTitle"
                                           Text="{Binding Name}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="16" FontWeight="SemiBold"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding Description}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="CardBorder"  Property="BorderBrush"  Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="CardBorder"  Property="Background"   Value="#1A2B44"/>
                                <Setter TargetName="CardTitle"   Property="Foreground"   Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected"  Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#445566"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,48,0,32" HorizontalAlignment="Center">
            <TextBlock Text="CHOOSE YOUR STYLE"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="40" FontWeight="Bold"
                       TextAlignment="Center"
                       Margin="0,0,0,8"/>
            <Rectangle Height="3" Width="200"
                       Fill="{DynamicResource AccentBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>
            <TextBlock Text="Select an AI enhancement for your photos"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="17" TextAlignment="Center"/>
        </StackPanel>

        <!-- Loading / error text -->
        <TextBlock x:Name="LoadingText"
                   Grid.Row="1"
                   Text="Loading styles…"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="18" TextAlignment="Center"
                   VerticalAlignment="Center"/>

        <!-- Styles grid -->
        <ScrollViewer Grid.Row="1"
                      x:Name="StylesScroller"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="Collapsed">
            <ListBox x:Name="StylesListBox"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectionChanged="StylesListBox_SelectionChanged"
                     ItemContainerStyle="{StaticResource StyleCard}">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center" Margin="30,0"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <ContentPresenter/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="48,0,48,48">
            <Button Content="← BACK"
                    Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Left"
                    Padding="28,14" FontSize="16"
                    Click="Back_Click"/>
            <Button x:Name="ConfirmButton"
                    Content="CONFIRM STYLE →"
                    Style="{StaticResource KioskButton}"
                    HorizontalAlignment="Right"
                    Padding="28,14" FontSize="16"
                    IsEnabled="False"
                    Click="Confirm_Click"/>
        </Grid>
    </Grid>
</Page>
