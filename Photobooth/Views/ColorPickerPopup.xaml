<Window x:Class="Photobooth.Views.ColorPickerPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize"
        Width="400" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E"
        ShowInTaskbar="False">
    <Border BorderBrush="#2A3A5A" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Draggable title bar (no system chrome) -->
            <Border Grid.Row="0" Background="#0D1B2A"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="Pick a color"
                           Foreground="White" FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="16,0"/>
            </Border>

            <StackPanel Grid.Row="1" Margin="20,16,20,20">

                <!-- Saturation / Brightness canvas -->
                <Canvas x:Name="SbCanvas" Width="360" Height="280"
                        ClipToBounds="False" Cursor="Crosshair"
                        MouseDown="SbCanvas_MouseDown"
                        MouseMove="SbCanvas_MouseMove"
                        MouseUp="SbCanvas_MouseUp">
                    <!-- Bottom: white → hue colour (saturation axis) -->
                    <Rectangle Width="360" Height="280">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="White" Offset="0"/>
                                <GradientStop x:Name="SbHueStop" Color="#FF0000" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <!-- Top: transparent → black (brightness axis) -->
                    <Rectangle Width="360" Height="280">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="Black" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <!-- 28×28 draggable thumb -->
                    <Ellipse x:Name="SbThumb" Width="28" Height="28"
                             Stroke="White" StrokeThickness="2.5"
                             Fill="Transparent"
                             Canvas.Left="-14" Canvas.Top="-14"
                             IsHitTestVisible="False"/>
                </Canvas>

                <!-- Hue strip -->
                <Canvas x:Name="HueCanvas" Width="360" Height="44"
                        Margin="0,12,0,0" Cursor="Hand"
                        MouseDown="HueCanvas_MouseDown"
                        MouseMove="HueCanvas_MouseMove"
                        MouseUp="HueCanvas_MouseUp">
                    <Rectangle Width="360" Height="44" RadiusX="4" RadiusY="4">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF0000" Offset="0"/>
                                <GradientStop Color="#FFFF00" Offset="0.167"/>
                                <GradientStop Color="#00FF00" Offset="0.333"/>
                                <GradientStop Color="#00FFFF" Offset="0.5"/>
                                <GradientStop Color="#0000FF" Offset="0.667"/>
                                <GradientStop Color="#FF00FF" Offset="0.833"/>
                                <GradientStop Color="#FF0000" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <!-- Sliding position indicator -->
                    <Rectangle x:Name="HueIndicator" Width="4" Height="44"
                               Fill="White" Canvas.Left="0" Canvas.Top="0"
                               IsHitTestVisible="False">
                        <Rectangle.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="4"
                                             Color="Black" Opacity="0.7"/>
                        </Rectangle.Effect>
                    </Rectangle>
                </Canvas>

                <!-- Before / After preview swatch -->
                <Grid Height="44" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="BeforePreview" Grid.Column="0"
                            CornerRadius="6,0,0,6"
                            BorderBrush="#2A3A5A" BorderThickness="1,1,0,1"/>
                    <Border x:Name="AfterPreview" Grid.Column="1"
                            CornerRadius="0,6,6,0"
                            BorderBrush="#2A3A5A" BorderThickness="0,1,1,1"/>
                </Grid>

                <!-- OK / Cancel buttons -->
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Cancel" Height="52" FontSize="15"
                            Style="{StaticResource GhostButton}"
                            Click="Cancel_Click"/>
                    <Button Grid.Column="2" Content="OK" Height="52" FontSize="15"
                            Style="{StaticResource KioskButton}"
                            Click="OK_Click"/>
                </Grid>

            </StackPanel>
        </Grid>
    </Border>
</Window>
