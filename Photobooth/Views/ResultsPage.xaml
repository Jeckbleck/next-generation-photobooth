<Page x:Class="Photobooth.Views.ResultsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,40,0,24" HorizontalAlignment="Center">
            <TextBlock Text="YOUR PHOTOS"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="40" FontWeight="Bold"
                       TextAlignment="Center"
                       Margin="0,0,0,8"/>
            <Rectangle Height="3" Width="120"
                       Fill="{DynamicResource AccentBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Composed photostrip preview -->
        <Image x:Name="StripPreview"
               Grid.Row="1"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               RenderOptions.BitmapScalingMode="HighQuality"
               Margin="40,0"/>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="40,24,40,40">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock x:Name="PrintStatusText"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="14" TextAlignment="Center"
                           Margin="0,0,0,8"/>
                <Button x:Name="PrintButton"
                        Content="PRINT STRIP"
                        Style="{StaticResource KioskButton}"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16"
                        Visibility="Collapsed"
                        Click="PrintButton_Click"/>
                <TextBlock x:Name="ReturnCountdown"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="16" TextAlignment="Center"
                           Margin="0,0,0,12"/>
                <Button Content="START AGAIN"
                        Style="{StaticResource KioskButton}"
                        HorizontalAlignment="Center"
                        Click="StartAgain_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
