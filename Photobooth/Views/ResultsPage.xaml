<Page x:Class="Photobooth.Views.ResultsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,40,0,24" HorizontalAlignment="Center">
            <TextBlock Text="YOUR PHOTOS"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="40" FontWeight="Bold"
                       TextAlignment="Center"
                       Margin="0,0,0,8"/>
            <Rectangle Height="3" Width="120"
                       Fill="{StaticResource AccentBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- 3 photos side by side -->
        <UniformGrid Grid.Row="1"
                     Rows="1" Columns="3"
                     Margin="40,0">
            <Border Margin="12" CornerRadius="8"
                    Background="{StaticResource SurfaceBrush}">
                <Image x:Name="Photo1"
                       Stretch="UniformToFill"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>
            <Border Margin="12" CornerRadius="8"
                    Background="{StaticResource SurfaceBrush}">
                <Image x:Name="Photo2"
                       Stretch="UniformToFill"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>
            <Border Margin="12" CornerRadius="8"
                    Background="{StaticResource SurfaceBrush}">
                <Image x:Name="Photo3"
                       Stretch="UniformToFill"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>
        </UniformGrid>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="40,24,40,40">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock x:Name="ReturnCountdown"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="16" TextAlignment="Center"
                           Margin="0,0,0,12"/>
                <Button Content="START AGAIN"
                        Style="{StaticResource KioskButton}"
                        HorizontalAlignment="Center"
                        Click="StartAgain_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
