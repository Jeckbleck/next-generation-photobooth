<Page x:Class="Photobooth.Views.ResultsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,40,0,24" HorizontalAlignment="Center">
            <TextBlock Text="YOUR PHOTOS"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="40" FontWeight="Bold"
                       TextAlignment="Center"
                       Margin="0,0,0,8"/>
            <Rectangle Height="3" Width="120"
                       Fill="{DynamicResource AccentBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- ── 3-COLUMN MAIN CONTENT ─────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="60,0,60,40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: AI status + print controls -->
            <StackPanel Grid.Column="0"
                        VerticalAlignment="Center"
                        Margin="0,0,32,0">

                <Border x:Name="AIStatusPanel"
                        Background="{DynamicResource NavBrush}"
                        CornerRadius="8"
                        Padding="16,12"
                        Margin="0,0,0,20"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="AIStatusDot" Width="8" Height="8"
                                 Fill="{DynamicResource AccentBrush}"
                                 VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock x:Name="AIStatusText"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="14" VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="PrintStatusText"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="14" TextWrapping="Wrap"
                           Margin="0,0,0,14"/>
                <Button x:Name="PrintButton"
                        Content="PRINT STRIP"
                        Style="{StaticResource KioskButton}"
                        HorizontalAlignment="Left"
                        Visibility="Collapsed"
                        Click="PrintButton_Click"/>
            </StackPanel>

            <!-- CENTER: layered photostrip — fills column height, fully responsive -->
            <Grid Grid.Column="1" Margin="0,16,0,16">

                <!-- Back copy — tilted left, faded -->
                <Image x:Name="StripBack"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Opacity="0.70"
                       Panel.ZIndex="0"
                       RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <RotateTransform Angle="-7"/>
                            <TranslateTransform X="-22" Y="12"/>
                        </TransformGroup>
                    </Image.RenderTransform>
                    <Image.Effect>
                        <DropShadowEffect ShadowDepth="5" Direction="270"
                                          BlurRadius="14" Opacity="0.40"/>
                    </Image.Effect>
                </Image>

                <!-- Front copy — slight right tilt, full opacity -->
                <Image x:Name="StripPreview"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Panel.ZIndex="1"
                       RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <RotateTransform Angle="5"/>
                    </Image.RenderTransform>
                    <Image.Effect>
                        <DropShadowEffect ShadowDepth="10" Direction="270"
                                          BlurRadius="26" Opacity="0.60"/>
                    </Image.Effect>
                </Image>

            </Grid>

            <!-- RIGHT: countdown + start again -->
            <StackPanel Grid.Column="2"
                        VerticalAlignment="Center"
                        Margin="32,0,0,0">
                <TextBlock x:Name="ReturnCountdown"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="16" TextWrapping="Wrap"
                           Margin="0,0,0,20"/>
                <Button Content="START AGAIN"
                        Style="{StaticResource KioskButton}"
                        Click="StartAgain_Click"/>
            </StackPanel>

        </Grid>
    </Grid>
</Page>
