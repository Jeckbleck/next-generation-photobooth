<Window x:Class="Photobooth.Views.EventBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="All Events"
        Width="900" Height="650"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Grid Grid.Row="0" Margin="24,20,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchBox"
                     Background="{DynamicResource NavBrush}"
                     Foreground="White" BorderBrush="#334"
                     Padding="10,7" FontSize="13"
                     Margin="0,0,12,0"
                     TextChanged="SearchBox_TextChanged"/>

            <ComboBox x:Name="SortComboBox" Grid.Column="1"
                      Padding="8,6" FontSize="13"
                      Margin="0,0,12,0"
                      SelectionChanged="SortChanged">
                <ComboBoxItem Content="Newest first" IsSelected="True"/>
                <ComboBoxItem Content="Oldest first"/>
                <ComboBoxItem Content="Name A-Z"/>
                <ComboBoxItem Content="Name Z-A"/>
            </ComboBox>

            <ToggleButton x:Name="ShowArchivedToggle" Grid.Column="2"
                          Style="{StaticResource ToggleSwitch}"
                          VerticalAlignment="Center"
                          Checked="FilterChanged"
                          Unchecked="FilterChanged"/>
        </Grid>

        <!-- Card grid -->
        <Grid Grid.Row="1" Margin="24,0,24,0">

            <TextBlock x:Name="EmptyLabel"
                       Text="No events match your search."
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="15"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="Collapsed"/>

            <ItemsControl x:Name="CardGrid">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Cursor="Hand" Padding="0" BorderThickness="0"
                                Background="Transparent"
                                Margin="8"
                                Click="EventCard_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CardBorder"
                                            Background="{DynamicResource NavBrush}"
                                            CornerRadius="8"
                                            BorderBrush="#1E2F4A" BorderThickness="1"
                                            Opacity="{Binding CardOpacity}">
                                        <StackPanel>

                                            <!-- Thumbnail / placeholder -->
                                            <Grid Height="100" ClipToBounds="True">
                                                <Border Background="{DynamicResource BackgroundBrush}"
                                                        CornerRadius="8,8,0,0">
                                                    <StackPanel VerticalAlignment="Center"
                                                                HorizontalAlignment="Center">
                                                        <Rectangle Height="20" Width="54"
                                                                   Fill="#1E2F4A" RadiusX="2" RadiusY="2"
                                                                   Margin="0,0,0,5"/>
                                                        <Rectangle Height="20" Width="54"
                                                                   Fill="#1E2F4A" RadiusX="2" RadiusY="2"
                                                                   Margin="0,0,0,5"/>
                                                        <Rectangle Height="20" Width="54"
                                                                   Fill="#1E2F4A" RadiusX="2" RadiusY="2"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- Covers placeholder once Thumbnail is set -->
                                                <Image Source="{Binding Thumbnail}"
                                                       Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Grid>

                                            <!-- Card info -->
                                            <StackPanel Margin="12,10,12,12">
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="13" FontWeight="Bold"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding DateLabel}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="11"
                                                           Margin="0,0,0,5"/>
                                                <Border x:Name="ArchivedBadge"
                                                        Background="#7A4A00"
                                                        CornerRadius="4"
                                                        Padding="6,2"
                                                        HorizontalAlignment="Left"
                                                        Visibility="Collapsed">
                                                    <TextBlock Text="Archived"
                                                               Foreground="#E9A020"
                                                               FontSize="10" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>

                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CardBorder" Property="BorderBrush"
                                                    Value="{DynamicResource AccentBrush}"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsArchived}" Value="True">
                                            <Setter TargetName="ArchivedBadge" Property="Visibility"
                                                    Value="Visible"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!-- Bottom bar -->
        <Grid Grid.Row="2" Margin="24,12,24,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="TotalLabel"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="13" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="PrevButton" Content="Prev"
                        Style="{StaticResource GhostButton}"
                        Padding="14,6" FontSize="13"
                        Margin="0,0,10,0"
                        Click="Prev_Click"/>
                <TextBlock x:Name="PageLabel"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="13" VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <Button x:Name="NextButton" Content="Next"
                        Style="{StaticResource GhostButton}"
                        Padding="14,6" FontSize="13"
                        Click="Next_Click"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
