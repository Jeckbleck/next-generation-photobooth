<Page x:Class="Photobooth.Views.GreetingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundBrush}">

    <Page.Resources>
        <Style x:Key="SettingsNavButton" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="Foreground"                 Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize"                   Value="13"/>
            <Setter Property="FontWeight"                 Value="Normal"/>
            <Setter Property="Padding"                    Value="20,11"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness"            Value="3,0,0,0"/>
            <Setter Property="BorderBrush"                Value="Transparent"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A2B44"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsNavButtonActive" TargetType="Button" BasedOn="{StaticResource SettingsNavButton}">
            <Setter Property="Background"  Value="#1E2B47"/>
            <Setter Property="Foreground"  Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Main greeting content -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="THE NEXT GENERATION"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="20" FontWeight="Light"
                       TextAlignment="Center"
                       Margin="0,0,0,8"/>

            <TextBlock Text="PHOTOBOOTH"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="72" FontWeight="Bold"
                       TextAlignment="Center"
                       Margin="0,0,0,24"/>

            <Rectangle Height="3" Width="200"
                       Fill="{StaticResource AccentBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"/>

            <TextBlock Text="Tap the button below to start your session"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="18" TextAlignment="Center"
                       Margin="0,0,0,40"/>

            <Button x:Name="StartButton"
                    Content="START SESSION"
                    Style="{StaticResource KioskButton}"
                    HorizontalAlignment="Center"
                    Click="StartSession_Click"/>

            <!-- Shown only when no camera is detected -->
            <TextBlock x:Name="CameraStatusText"
                       Text="No camera connected"
                       Foreground="#FF6B6B"
                       FontSize="15"
                       TextAlignment="Center"
                       Margin="0,16,0,4"
                       Visibility="Collapsed"/>

            <Button x:Name="RetryButton"
                    Content="RETRY CONNECTION"
                    Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Center"
                    Padding="28,10" FontSize="15"
                    Margin="0,0,0,0"
                    Visibility="Collapsed"
                    Click="RetryCamera_Click"/>
        </StackPanel>

        <!-- Gear / settings button — top-right corner -->
        <Button x:Name="GearButton"
                Width="48" Height="48"
                Margin="0,24,24,0"
                VerticalAlignment="Top" HorizontalAlignment="Right"
                Background="Transparent" BorderThickness="0"
                Cursor="Hand"
                ToolTip="Staff settings"
                Click="GearButton_Click">
            <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                  Fill="#555577" Stretch="Uniform" Width="24" Height="24"/>
        </Button>

        <!-- Settings overlay (hidden by default) -->
        <Grid x:Name="SettingsOverlay" Visibility="Collapsed">
            <Rectangle Fill="#B0000000"/>

            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="12"
                    Width="420"
                    Padding="40"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>

                    <TextBlock Text="Staff Settings"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="26" FontWeight="Bold"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Enter PIN to continue"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="15"
                               Margin="0,0,0,16"/>

                    <PasswordBox x:Name="PinBox"
                                 MaxLength="6"
                                 FontSize="24"
                                 Background="#0D1B2A"
                                 Foreground="White"
                                 BorderBrush="#334"
                                 Padding="12,8"
                                 Margin="0,0,0,8"
                                 KeyDown="PinBox_KeyDown"/>

                    <TextBlock x:Name="PinError"
                               Text="Incorrect PIN"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="14"
                               Visibility="Collapsed"
                               Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel"
                                Style="{StaticResource GhostButton}"
                                Padding="24,10"
                                FontSize="15"
                                Margin="0,0,12,0"
                                Click="CancelSettings_Click"/>
                        <Button Content="Unlock"
                                Style="{StaticResource KioskButton}"
                                Padding="24,10"
                                FontSize="15"
                                Click="UnlockSettings_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Settings content panel (shown after correct PIN) -->
        <Grid x:Name="SettingsContentPanel" Visibility="Collapsed">
            <Rectangle Fill="#B0000000"/>

            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="12" Width="780" MaxHeight="600"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="185"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sidebar -->
                    <Border Grid.Column="0" Background="#0D1424" CornerRadius="12,0,0,12">
                        <StackPanel Margin="0,28,0,28">
                            <TextBlock Text="Settings"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="17" FontWeight="Bold"
                                       Margin="20,0,20,20"/>
                            <Button x:Name="NavEvents"  Content="Event Management"  Style="{StaticResource SettingsNavButtonActive}" Click="Nav_Click"/>
                            <Button x:Name="NavCamera"  Content="Camera"            Style="{StaticResource SettingsNavButton}"       Click="Nav_Click"/>
                            <Button x:Name="NavStrip"   Content="Strip"             Style="{StaticResource SettingsNavButton}"       Click="Nav_Click"/>
                            <Button x:Name="NavPrinter" Content="Printer"           Style="{StaticResource SettingsNavButton}"       Click="Nav_Click"/>
                            <Button x:Name="NavDisplay" Content="Display"           Style="{StaticResource SettingsNavButton}"       Click="Nav_Click"/>
                            <Button x:Name="NavAI"      Content="AI Enhancement"   Style="{StaticResource SettingsNavButton}"       Click="Nav_Click"/>
                            <Button x:Name="NavSync"    Content="Sync &amp; Backup" Style="{StaticResource SettingsNavButton}"       Click="Nav_Click"/>
                            <Button x:Name="NavAbout"   Content="About"             Style="{StaticResource SettingsNavButton}"       Click="Nav_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Content area -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="28,28,28,0">
                            <Grid>

                                <!-- EVENT MANAGEMENT -->
                                <StackPanel x:Name="PanelEvents" Visibility="Visible">
                                    <TextBlock Text="Event Management" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" FontWeight="Bold" Margin="0,0,0,20"/>

                                    <TextBlock Text="ACTIVE EVENT" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

                                    <TextBlock Text="Select event" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                                    <ComboBox Foreground="Black" BorderBrush="#334" FontSize="13" Padding="8,6" Margin="0,0,0,10">
                                        <ComboBoxItem Content="— Select event —" IsSelected="True"/>
                                        <ComboBoxItem Content="Summer Bash 2026"/>
                                        <ComboBoxItem Content="Corporate Gala Q2"/>
                                        <ComboBoxItem Content="Birthday Party – May 4"/>
                                    </ComboBox>

                                    <TextBlock Text="Event name" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                                    <TextBox Background="#0D1B2A" Foreground="White" BorderBrush="#334" Padding="10,7" FontSize="13" Margin="0,0,0,20"/>

                                    <TextBlock Text="STORAGE" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

                                    <TextBlock Text="Save photos to" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Background="#0D1B2A" Foreground="White" BorderBrush="#334" Padding="10,7" FontSize="12"
                                                 Text="C:\Users\Pictures\Photobooth" VerticalContentAlignment="Center"/>
                                        <Button Grid.Column="1" Content="Browse"
                                                Style="{StaticResource GhostButton}"
                                                Padding="14,6" FontSize="13" Margin="8,0,0,0"/>
                                    </Grid>

                                    <TextBlock Text="SESSION PREVIEW" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

                                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,20">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="#0D1B2A" CornerRadius="6" Width="100" Height="82" Margin="0,0,8,4" BorderBrush="#1E2F4A" BorderThickness="1">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="Session 1" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="3 photos" Foreground="#555577" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#0D1B2A" CornerRadius="6" Width="100" Height="82" Margin="0,0,8,4" BorderBrush="#1E2F4A" BorderThickness="1">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="Session 2" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="3 photos" Foreground="#555577" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#0D1B2A" CornerRadius="6" Width="100" Height="82" Margin="0,0,8,4" BorderBrush="#1E2F4A" BorderThickness="1">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="Session 3" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="3 photos" Foreground="#555577" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#141F2E" CornerRadius="6" Width="100" Height="82" Margin="0,0,0,4" BorderBrush="#1E2F4A" BorderThickness="1" Cursor="Hand">
                                                <TextBlock Text="+" Foreground="{StaticResource TextSecondaryBrush}" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <TextBlock Text="SESSION DATA" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#0D1B2A" CornerRadius="8" Padding="16,12" Margin="0,0,6,0">
                                            <StackPanel>
                                                <TextBlock Text="Sessions" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                                <TextBlock Text="—" Foreground="{StaticResource TextPrimaryBrush}" FontSize="22" FontWeight="Bold"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Background="#0D1B2A" CornerRadius="8" Padding="16,12" Margin="6,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Photos" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                                <TextBlock Text="—" Foreground="{StaticResource TextPrimaryBrush}" FontSize="22" FontWeight="Bold"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <Button Content="Clear session data"
                                            Style="{StaticResource GhostButton}"
                                            HorizontalAlignment="Left" Padding="18,7" FontSize="13"
                                            Foreground="{StaticResource AccentBrush}"
                                            BorderBrush="{StaticResource AccentBrush}"
                                            Margin="0,4,0,0"/>
                                </StackPanel>

                                <!-- CAMERA SETTINGS -->
                                <StackPanel x:Name="PanelCamera" Visibility="Collapsed">
                                    <TextBlock Text="Camera Settings" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" FontWeight="Bold" Margin="0,0,0,20"/>

                                    <TextBlock Text="EXPOSURE" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="ISO" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" Foreground="Black" BorderBrush="#334" FontSize="13" Padding="8,6">
                                            <ComboBoxItem Content="Auto" IsSelected="True"/><ComboBoxItem Content="100"/><ComboBoxItem Content="200"/><ComboBoxItem Content="400"/><ComboBoxItem Content="800"/><ComboBoxItem Content="1600"/>
                                        </ComboBox>
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Shutter speed" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" Foreground="Black" BorderBrush="#334" FontSize="13" Padding="8,6">
                                            <ComboBoxItem Content="1/60"/><ComboBoxItem Content="1/100"/><ComboBoxItem Content="1/125" IsSelected="True"/><ComboBoxItem Content="1/200"/><ComboBoxItem Content="1/250"/>
                                        </ComboBox>
                                    </Grid>
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Aperture" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" Foreground="Black" BorderBrush="#334" FontSize="13" Padding="8,6">
                                            <ComboBoxItem Content="f/2.8"/><ComboBoxItem Content="f/4"/><ComboBoxItem Content="f/5.6"/><ComboBoxItem Content="f/8" IsSelected="True"/><ComboBoxItem Content="f/11"/>
                                        </ComboBox>
                                    </Grid>

                                    <TextBlock Text="COLOR" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="White balance" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" Foreground="Black" BorderBrush="#334" FontSize="13" Padding="8,6">
                                            <ComboBoxItem Content="Auto" IsSelected="True"/><ComboBoxItem Content="Daylight"/><ComboBoxItem Content="Cloudy"/><ComboBoxItem Content="Tungsten"/><ComboBoxItem Content="Flash"/>
                                        </ComboBox>
                                    </Grid>

                                    <TextBlock Text="FILE" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Image quality" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" Foreground="Black" BorderBrush="#334" FontSize="13" Padding="8,6">
                                            <ComboBoxItem Content="JPEG Fine" IsSelected="True"/><ComboBoxItem Content="JPEG Normal"/><ComboBoxItem Content="RAW + JPEG"/>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>

                                <!-- STRIP CUSTOMIZATION -->
                                <StackPanel x:Name="PanelStrip" Visibility="Collapsed">
                                    <TextBlock Text="Strip Customization" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" FontWeight="Bold" Margin="0,0,0,20"/>

                                    <TextBlock Text="BRANDING" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

                                    <TextBlock Text="Branding text" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                                    <TextBox Background="#0D1B2A" Foreground="White" BorderBrush="#334" Padding="10,7" FontSize="13" Margin="0,0,0,10" Text="THE NEXT GENERATION PHOTOBOOTH"/>
                                    <TextBlock Text="Font" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                                    <ComboBox Foreground="Black" BorderBrush="#334" FontSize="13" Padding="8,6" Margin="0,0,0,10">
                                        <ComboBoxItem Content="Arial" IsSelected="True"/><ComboBoxItem Content="Segoe UI"/><ComboBoxItem Content="Helvetica"/><ComboBoxItem Content="Georgia"/>
                                    </ComboBox>
                                    <TextBlock Text="Logo image" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                                    <Border Background="#0D1B2A" BorderBrush="#334" BorderThickness="1" CornerRadius="6" Height="54" Margin="0,0,0,20">
                                        <TextBlock Text="+ Upload logo  (coming soon)" Foreground="#555577" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <TextBlock Text="LAYOUT" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

                                    <TextBlock Text="Background" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <RadioButton Content="White" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" GroupName="StripBg" IsChecked="True" Margin="0,0,20,0"/>
                                        <RadioButton Content="Black" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" GroupName="StripBg"/>
                                    </StackPanel>
                                    <TextBlock Text="Border style" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <RadioButton Content="None"  Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" GroupName="StripBorder" IsChecked="True" Margin="0,0,20,0"/>
                                        <RadioButton Content="Thin"  Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" GroupName="StripBorder" Margin="0,0,20,0"/>
                                        <RadioButton Content="Thick" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" GroupName="StripBorder"/>
                                    </StackPanel>
                                    <TextBlock Text="Photo fit" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton Content="Letterbox"   Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" GroupName="StripFit" IsChecked="True" Margin="0,0,20,0"/>
                                        <RadioButton Content="Fill / Crop" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" GroupName="StripFit"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- PRINTER -->
                                <StackPanel x:Name="PanelPrinter" Visibility="Collapsed">
                                    <TextBlock Text="Printer" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" FontWeight="Bold" Margin="0,0,0,20"/>

                                    <TextBlock Text="CONNECTION" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

                                    <TextBlock x:Name="PrinterStatusText" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBox x:Name="PrinterNameBox" Width="260" Background="#0D1B2A" Foreground="White" BorderBrush="#334" Padding="10,7" FontSize="13" ToolTip="Leave blank to auto-detect any DNP printer"/>
                                        <Button Content="Auto-detect" Style="{StaticResource GhostButton}" Padding="14,6" FontSize="13" Margin="8,0,0,0" Click="AutoDetectPrinter_Click"/>
                                    </StackPanel>
                                    <TextBlock Text="Leave blank to auto-detect any DNP / DS620 printer." Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,20"/>

                                    <TextBlock Text="PAPER" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Paper size" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="Portrait 4×6  (auto)" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Copies" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" Foreground="Black" BorderBrush="#334" FontSize="13" Padding="8,6" Width="70" HorizontalAlignment="Left">
                                            <ComboBoxItem Content="1" IsSelected="True"/><ComboBoxItem Content="2"/>
                                        </ComboBox>
                                    </Grid>

                                    <Border Background="#0D1B2A" CornerRadius="8" Padding="14,10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⚠" Foreground="#E9A020" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Top"/>
                                            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                                                Enable <Run FontWeight="Bold" Foreground="White">2-inch cut</Run> in the DNP driver once: Printer Properties → Advanced → Printing Defaults → Printer Features → 2 inch cut.
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- DISPLAY -->
                                <StackPanel x:Name="PanelDisplay" Visibility="Collapsed">
                                    <TextBlock Text="Display" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" FontWeight="Bold" Margin="0,0,0,20"/>

                                    <TextBlock Text="COUNTDOWN" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/><ColumnDefinition Width="36"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Countdown" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="3" Maximum="10" Value="3" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="3 s" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    </Grid>

                                    <TextBlock Text="SESSION" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/><ColumnDefinition Width="36"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Preview hold" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="1" Maximum="10" Value="5" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="5 s" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Idle return" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" Foreground="Black" BorderBrush="#334" FontSize="13" Padding="8,6">
                                            <ComboBoxItem Content="15 seconds"/><ComboBoxItem Content="30 seconds" IsSelected="True"/><ComboBoxItem Content="60 seconds"/><ComboBoxItem Content="Never"/>
                                        </ComboBox>
                                    </Grid>

                                    <TextBlock Text="FEATURES" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>
                                    <CheckBox Content="Show attract screen when idle" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                                </StackPanel>

                                <!-- AI ENHANCEMENT -->
                                <StackPanel x:Name="PanelAI" Visibility="Collapsed">
                                    <TextBlock Text="AI Enhancement" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" LineHeight="20" Margin="0,0,0,20">
                                        Enhance photos with AI-powered style processing via a local FastAPI server before printing and display. The server runs separately on this machine or on the local network.
                                    </TextBlock>

                                    <TextBlock Text="CONNECTION" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

                                    <CheckBox Content="Enable AI Enhancement" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,10"/>
                                    <TextBlock Text="Server URL" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                                    <TextBox Background="#0D1B2A" Foreground="White" BorderBrush="#334" Padding="10,7" FontSize="13" Margin="0,0,0,20" Text="http://localhost:8000"/>

                                    <TextBlock Text="STYLE" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Style preset" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" Foreground="Black" BorderBrush="#334" FontSize="13" Padding="8,6">
                                            <ComboBoxItem Content="Natural" IsSelected="True"/><ComboBoxItem Content="Vivid"/><ComboBoxItem Content="B&amp;W Film"/><ComboBoxItem Content="Vintage"/>
                                        </ComboBox>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="#555577" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Not connected — AI processing disabled" Foreground="#555577" FontSize="13"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- SYNC & BACKUP -->
                                <StackPanel x:Name="PanelSync" Visibility="Collapsed">
                                    <TextBlock Text="Sync &amp; Backup" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" LineHeight="20" Margin="0,0,0,20">
                                        Automatically back up session photos to a Synology NAS or any SMB/SFTP network storage after each session. The kiosk continues to operate offline if the server is unreachable.
                                    </TextBlock>

                                    <TextBlock Text="SERVER" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

                                    <TextBlock Text="NAS address" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                                    <TextBox Background="#0D1B2A" Foreground="White" BorderBrush="#334" Padding="10,7" FontSize="13" Margin="0,0,0,10" Text="192.168.1.x"/>
                                    <TextBlock Text="Username" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                                    <TextBox Background="#0D1B2A" Foreground="White" BorderBrush="#334" Padding="10,7" FontSize="13" Margin="0,0,0,10"/>
                                    <TextBlock Text="Password" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                                    <PasswordBox Background="#0D1B2A" Foreground="White" BorderBrush="#334" Padding="10,7" FontSize="13" Margin="0,0,0,20"/>

                                    <TextBlock Text="SCHEDULE" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

                                    <CheckBox Content="Enable automatic sync" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,10"/>
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Sync when" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" Foreground="Black" BorderBrush="#334" FontSize="13" Padding="8,6">
                                            <ComboBoxItem Content="After each session" IsSelected="True"/><ComboBoxItem Content="Every hour"/><ComboBoxItem Content="End of event"/><ComboBoxItem Content="Manually"/>
                                        </ComboBox>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="#555577" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Not configured" Foreground="#555577" FontSize="13"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- ABOUT -->
                                <StackPanel x:Name="PanelAbout" Visibility="Collapsed">
                                    <TextBlock Text="The Next Generation Photobooth" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="AboutVersion" Text="Version 1.0.0-dev" Foreground="{StaticResource AccentBrush}" FontSize="13" Margin="0,0,0,24"/>

                                    <TextBlock Text="DEVICES" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Camera" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock x:Name="AboutCameraModel" Text="—" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                            <TextBlock x:Name="AboutCameraStatus" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Printer" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock x:Name="AboutPrinterModel" Text="—" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                            <TextBlock x:Name="AboutPrinterStatus" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="FILES" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Log files" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                                        <TextBlock x:Name="AboutLogPath" Grid.Column="1" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" TextWrapping="Wrap"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Sessions" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                                        <TextBlock x:Name="AboutSessionsPath" Grid.Column="1" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" TextWrapping="Wrap"/>
                                    </Grid>

                                    <TextBlock Text="RUNTIME" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>
                                    <TextBlock Text=".NET 10  ·  Canon EDSDK 13.20.10  ·  WPF" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                </StackPanel>

                            </Grid>
                        </ScrollViewer>

                        <!-- Footer -->
                        <StackPanel Grid.Row="1" HorizontalAlignment="Right" Margin="28,14,28,22">
                            <Button Content="Close"
                                    Style="{StaticResource KioskButton}"
                                    Padding="24,10" FontSize="15"
                                    Click="CloseSettingsContent_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
