<UserControl x:Class="Photobooth.Views.EventStatsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Statistics" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" FontWeight="Bold" Margin="0,0,0,20"/>

        <TextBlock Text="SESSION DATA" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
        <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{DynamicResource NavBrush}" CornerRadius="8" Padding="16,12" Margin="0,0,4,0">
                <StackPanel>
                    <TextBlock Text="Sessions" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBlock x:Name="SessionCountText" Text="—" Foreground="{StaticResource TextPrimaryBrush}" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="{DynamicResource NavBrush}" CornerRadius="8" Padding="16,12" Margin="4,0,4,0">
                <StackPanel>
                    <TextBlock Text="Photos" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBlock x:Name="PhotoCountText" Text="—" Foreground="{StaticResource TextPrimaryBrush}" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="{DynamicResource NavBrush}" CornerRadius="8" Padding="16,12" Margin="4,0,4,0">
                <StackPanel>
                    <TextBlock Text="Prints" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBlock x:Name="PrintCountText" Text="—" Foreground="{StaticResource TextPrimaryBrush}" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Background="{DynamicResource NavBrush}" CornerRadius="8" Padding="16,12" Margin="4,0,0,0">
                <StackPanel>
                    <TextBlock Text="AI boosts" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBlock x:Name="AICountText" Text="—" Foreground="{StaticResource TextPrimaryBrush}" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>
        <Button Content="Clear session data"
                Style="{StaticResource GhostButton}"
                HorizontalAlignment="Left" Padding="18,7" FontSize="13"
                Margin="0,4,0,14"
                Click="ClearSessionData_Click"/>
    </StackPanel>
</UserControl>
