<UserControl x:Class="Photobooth.Views.StripDesignerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <!-- Local toggle-switch style (mirrors the one in GreetingPage) -->
        <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track" Width="42" Height="24" CornerRadius="12" Background="#334">
                            <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="White"
                                     HorizontalAlignment="Left" Margin="3,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab-style RadioButton: underline border when checked -->
        <Style x:Key="TabToggle" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="0,0,0,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" BorderThickness="0,0,0,2"
                                BorderBrush="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ Left: Controls panel ══════════════════════════════════════════════ -->
        <StackPanel Grid.Column="0" Margin="0,0,20,0" VerticalAlignment="Top">

            <!-- TEMPLATE section -->
            <TextBlock Text="TEMPLATE"
                       Foreground="{DynamicResource AccentBrush}"
                       FontSize="11" FontWeight="Bold"
                       Margin="0,0,0,6"/>
            <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,10"/>

            <Button x:Name="UploadButton"
                    Content="Upload Template"
                    Style="{StaticResource GhostButton}"
                    Padding="10,7" FontSize="12"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,0,6"
                    Click="Upload_Click"/>

            <Button x:Name="SaveButton"
                    Content="Save"
                    Style="{StaticResource GhostButton}"
                    Padding="10,7" FontSize="12"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,0,6"
                    IsEnabled="False"
                    Click="Save_Click"/>

            <Button x:Name="ClearButton"
                    Content="Clear All"
                    Style="{StaticResource GhostButton}"
                    Padding="10,7" FontSize="12"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,0,0"
                    IsEnabled="False"
                    Click="Clear_Click"/>

            <!-- BACKGROUND section -->
            <TextBlock Text="BACKGROUND"
                       Foreground="{DynamicResource AccentBrush}"
                       FontSize="11" FontWeight="Bold"
                       Margin="0,18,0,6"/>
            <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,10"/>

            <Button x:Name="BackgroundColorButton"
                    Content="Set Background Color"
                    Style="{StaticResource GhostButton}"
                    Padding="10,7" FontSize="12"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,0,6"
                    IsEnabled="False"
                    Click="BackgroundColor_Click"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="BackgroundColorSwatch"
                        Grid.Column="0"
                        Height="24" CornerRadius="3"
                        Background="Transparent"
                        BorderBrush="#334" BorderThickness="1"
                        Visibility="Collapsed"/>
                <Button x:Name="ClearBackgroundColorButton"
                        Grid.Column="1"
                        Content="×"
                        Style="{StaticResource GhostButton}"
                        Padding="8,2" FontSize="12"
                        Margin="6,0,0,0"
                        Visibility="Collapsed"
                        Click="ClearBackgroundColor_Click"/>
            </Grid>

            <!-- SLOTS section -->
            <TextBlock Text="SLOTS"
                       Foreground="{DynamicResource AccentBrush}"
                       FontSize="11" FontWeight="Bold"
                       Margin="0,18,0,6"/>
            <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,10"/>

            <!-- Mode tab switcher -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <RadioButton x:Name="AutoDetectTab"
                             Content="Auto-detect"
                             GroupName="SlotMode"
                             Style="{StaticResource TabToggle}"
                             IsChecked="True"
                             Margin="0,0,16,0"
                             Checked="SlotModeTab_Changed"/>
                <RadioButton x:Name="ManualTab"
                             Content="Manual"
                             GroupName="SlotMode"
                             Style="{StaticResource TabToggle}"
                             Checked="SlotModeTab_Changed"/>
            </StackPanel>

            <!-- Auto-detect panel -->
            <StackPanel x:Name="AutoDetectPanel" Visibility="Visible">
                <Button x:Name="EyedropperButton"
                        Content="Pick Color"
                        Style="{StaticResource GhostButton}"
                        Padding="10,7" FontSize="12"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,6"
                        IsEnabled="False"
                        Click="Eyedropper_Click"/>
                <Border x:Name="ColorSwatch"
                        Height="24" CornerRadius="3"
                        Background="Transparent"
                        BorderBrush="#334" BorderThickness="1"
                        Margin="0,0,0,8"
                        Visibility="Collapsed"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="Tolerance"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock x:Name="ToleranceLabel"
                               Text="15"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <Slider x:Name="ToleranceSlider"
                        Minimum="0" Maximum="50" Value="15"
                        IsEnabled="False"
                        Margin="0,0,0,8"
                        ValueChanged="ToleranceSlider_ValueChanged"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="Edge Margin"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock x:Name="EdgeMarginLabel"
                               Text="3"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <Slider x:Name="EdgeMarginSlider"
                        Minimum="0" Maximum="10" Value="3"
                        IsEnabled="False"
                        Margin="0,0,0,8"
                        ValueChanged="EdgeMarginSlider_ValueChanged"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="Photo Overlap"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock x:Name="PhotoOverlapLabel"
                               Text="6"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <Slider x:Name="PhotoOverlapSlider"
                        Minimum="0" Maximum="15" Value="6"
                        IsEnabled="False"
                        Margin="0,0,0,8"
                        ValueChanged="PhotoOverlapSlider_ValueChanged"/>
            </StackPanel>

            <!-- Manual panel -->
            <StackPanel x:Name="ManualPanel" Visibility="Collapsed">
                <Button x:Name="AddSlotButton"
                        Content="+ Add Slot"
                        Style="{StaticResource GhostButton}"
                        Padding="10,7" FontSize="12"
                        HorizontalAlignment="Stretch"
                        IsEnabled="False"
                        Click="AddSlot_Click"/>
            </StackPanel>

            <!-- TEXT section -->
            <TextBlock Text="TEXT"
                       Foreground="{DynamicResource AccentBrush}"
                       FontSize="11" FontWeight="Bold"
                       Margin="0,18,0,6"/>
            <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,10"/>

            <Button x:Name="AddTextButton"
                    Content="+ Add Text"
                    Style="{StaticResource GhostButton}"
                    Padding="10,7" FontSize="12"
                    HorizontalAlignment="Stretch"
                    IsEnabled="False"
                    Click="AddText_Click"/>

            <!-- VIEW section -->
            <TextBlock Text="VIEW"
                       Foreground="{DynamicResource AccentBrush}"
                       FontSize="11" FontWeight="Bold"
                       Margin="0,18,0,6"/>
            <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,10"/>

            <!-- Zoom controls -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="ZoomOutButton"
                        Content="－"
                        Style="{StaticResource GhostButton}"
                        Padding="8,5" FontSize="12"
                        Margin="0,0,6,0"
                        Click="ZoomOut_Click"/>
                <TextBlock x:Name="ZoomLabel"
                           Text="100%"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           MinWidth="40"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <Button x:Name="ZoomInButton"
                        Content="＋"
                        Style="{StaticResource GhostButton}"
                        Padding="8,5" FontSize="12"
                        Click="ZoomIn_Click"/>
            </StackPanel>

            <!-- Guidelines toggle -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Guidelines"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="12"/>
                    <TextBlock Text="Snap slots to grid"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="10"
                               Margin="0,1,0,0"/>
                </StackPanel>
                <ToggleButton x:Name="GuidelinesToggle"
                              Grid.Column="1"
                              Style="{StaticResource ToggleSwitch}"
                              VerticalAlignment="Center"
                              Click="GuidelinesToggle_Click"/>
            </Grid>

            <!-- Divider + status -->
            <Rectangle Height="1" Fill="#1E2F4A" Margin="0,14,0,10"/>

            <TextBlock x:Name="StatusText"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- ══ Right: Canvas ═════════════════════════════════════════════════════ -->
        <ScrollViewer x:Name="CanvasScroller"
                      Grid.Column="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      PanningMode="None"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#080D14"
                      ScrollChanged="CanvasScroller_ScrollChanged"
                      PreviewMouseDown="CanvasScroller_PreviewMouseDown"
                      PreviewMouseMove="CanvasScroller_PreviewMouseMove"
                      PreviewMouseUp="CanvasScroller_PreviewMouseUp">
            <!-- CanvasContainer MinWidth/MinHeight are set from code-behind to match the
                 viewport so that HorizontalAlignment="Center" on the Border actually works
                 when the canvas is narrower than the scrollviewer. -->
            <Grid x:Name="CanvasContainer">
                <Border BorderBrush="#334" BorderThickness="1"
                        Background="#080D14"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="16">
                    <Canvas x:Name="DesignerCanvas"
                            Width="150" Height="450"
                            ClipToBounds="True"
                            Background="Transparent"
                            MouseWheel="DesignerCanvas_MouseWheel"
                            PreviewMouseLeftButtonDown="DesignerCanvas_PreviewMouseDown">
                        <Canvas.LayoutTransform>
                            <ScaleTransform x:Name="ZoomTransform" ScaleX="1" ScaleY="1"/>
                        </Canvas.LayoutTransform>
                        <Image x:Name="TemplateImage"
                               Canvas.Left="0" Canvas.Top="0"
                               Width="150" Height="450"
                               Stretch="Uniform"
                               IsHitTestVisible="False"/>
                    </Canvas>
                </Border>
            </Grid>
        </ScrollViewer>

    </Grid>
</UserControl>
