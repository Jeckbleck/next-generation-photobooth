<UserControl x:Class="Photobooth.Views.StripDesignerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>

        <!-- Toolbar -->
        <WrapPanel Margin="0,0,0,12">
            <Button x:Name="UploadButton"
                    Content="Upload Template"
                    Style="{StaticResource GhostButton}"
                    Padding="12,6" FontSize="12"
                    Margin="0,0,8,4"
                    Click="Upload_Click"/>
            <Button x:Name="AddSlotButton"
                    Content="+ Add Slot"
                    Style="{StaticResource GhostButton}"
                    Padding="12,6" FontSize="12"
                    Margin="0,0,8,4"
                    IsEnabled="False"
                    Click="AddSlot_Click"/>
            <Button x:Name="SaveButton"
                    Content="Save"
                    Style="{StaticResource GhostButton}"
                    Padding="12,6" FontSize="12"
                    Margin="0,0,8,4"
                    IsEnabled="False"
                    Click="Save_Click"/>
            <Button x:Name="ClearButton"
                    Content="Clear All"
                    Style="{StaticResource GhostButton}"
                    Padding="12,6" FontSize="12"
                    Margin="0,0,0,4"
                    IsEnabled="False"
                    Click="Clear_Click"/>
        </WrapPanel>

        <!-- Canvas area -->
        <Border BorderBrush="#334" BorderThickness="1"
                Background="#080D14"
                HorizontalAlignment="Left"
                Width="300" Height="450">
            <Canvas x:Name="DesignerCanvas"
                    Width="300" Height="450"
                    ClipToBounds="True"
                    Background="Transparent">
                <Image x:Name="TemplateImage"
                       Canvas.Left="0" Canvas.Top="0"
                       Width="300" Height="450"
                       Stretch="Fill"
                       IsHitTestVisible="False"/>
            </Canvas>
        </Border>

        <!-- Status / hint -->
        <TextBlock x:Name="StatusText"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="12" TextWrapping="Wrap"
                   Margin="0,10,0,0"/>

    </StackPanel>
</UserControl>
