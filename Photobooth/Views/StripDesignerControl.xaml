<UserControl x:Class="Photobooth.Views.StripDesignerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <!-- Local toggle-switch style (mirrors the one in GreetingPage) -->
        <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track" Width="42" Height="24" CornerRadius="12" Background="#334">
                            <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="White"
                                     HorizontalAlignment="Left" Margin="3,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ Left: Controls panel ══════════════════════════════════════════════ -->
        <StackPanel Grid.Column="0" Margin="0,0,20,0" VerticalAlignment="Top">

            <!-- TEMPLATE section -->
            <TextBlock Text="TEMPLATE"
                       Foreground="{DynamicResource AccentBrush}"
                       FontSize="11" FontWeight="Bold"
                       Margin="0,0,0,6"/>
            <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,10"/>

            <Button x:Name="UploadButton"
                    Content="Upload Template"
                    Style="{StaticResource GhostButton}"
                    Padding="10,7" FontSize="12"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,0,6"
                    Click="Upload_Click"/>

            <Button x:Name="SaveButton"
                    Content="Save"
                    Style="{StaticResource GhostButton}"
                    Padding="10,7" FontSize="12"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,0,6"
                    IsEnabled="False"
                    Click="Save_Click"/>

            <Button x:Name="ClearButton"
                    Content="Clear All"
                    Style="{StaticResource GhostButton}"
                    Padding="10,7" FontSize="12"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,0,0"
                    IsEnabled="False"
                    Click="Clear_Click"/>

            <!-- SLOTS section -->
            <TextBlock Text="SLOTS"
                       Foreground="{DynamicResource AccentBrush}"
                       FontSize="11" FontWeight="Bold"
                       Margin="0,18,0,6"/>
            <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,10"/>

            <Button x:Name="AddSlotButton"
                    Content="+ Add Slot"
                    Style="{StaticResource GhostButton}"
                    Padding="10,7" FontSize="12"
                    HorizontalAlignment="Stretch"
                    IsEnabled="False"
                    Click="AddSlot_Click"/>

            <!-- VIEW section -->
            <TextBlock Text="VIEW"
                       Foreground="{DynamicResource AccentBrush}"
                       FontSize="11" FontWeight="Bold"
                       Margin="0,18,0,6"/>
            <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,10"/>

            <!-- Zoom controls -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="ZoomOutButton"
                        Content="－"
                        Style="{StaticResource GhostButton}"
                        Padding="8,5" FontSize="12"
                        Margin="0,0,6,0"
                        Click="ZoomOut_Click"/>
                <TextBlock x:Name="ZoomLabel"
                           Text="100%"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           MinWidth="40"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <Button x:Name="ZoomInButton"
                        Content="＋"
                        Style="{StaticResource GhostButton}"
                        Padding="8,5" FontSize="12"
                        Click="ZoomIn_Click"/>
            </StackPanel>

            <!-- Guidelines toggle -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Guidelines"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="12"/>
                    <TextBlock Text="Snap slots to grid"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="10"
                               Margin="0,1,0,0"/>
                </StackPanel>
                <ToggleButton x:Name="GuidelinesToggle"
                              Grid.Column="1"
                              Style="{StaticResource ToggleSwitch}"
                              VerticalAlignment="Center"
                              Click="GuidelinesToggle_Click"/>
            </Grid>

            <!-- Divider + status -->
            <Rectangle Height="1" Fill="#1E2F4A" Margin="0,14,0,10"/>

            <TextBlock x:Name="StatusText"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- ══ Right: Canvas ═════════════════════════════════════════════════════ -->
        <ScrollViewer x:Name="CanvasScroller"
                      Grid.Column="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      PanningMode="None"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#080D14"
                      ScrollChanged="CanvasScroller_ScrollChanged"
                      PreviewMouseDown="CanvasScroller_PreviewMouseDown"
                      PreviewMouseMove="CanvasScroller_PreviewMouseMove"
                      PreviewMouseUp="CanvasScroller_PreviewMouseUp">
            <!-- CanvasContainer MinWidth/MinHeight are set from code-behind to match the
                 viewport so that HorizontalAlignment="Center" on the Border actually works
                 when the canvas is narrower than the scrollviewer. -->
            <Grid x:Name="CanvasContainer">
                <Border BorderBrush="#334" BorderThickness="1"
                        Background="#080D14"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="16">
                    <Canvas x:Name="DesignerCanvas"
                            Width="150" Height="450"
                            ClipToBounds="True"
                            Background="Transparent"
                            MouseWheel="DesignerCanvas_MouseWheel">
                        <Canvas.LayoutTransform>
                            <ScaleTransform x:Name="ZoomTransform" ScaleX="1" ScaleY="1"/>
                        </Canvas.LayoutTransform>
                        <Image x:Name="TemplateImage"
                               Canvas.Left="0" Canvas.Top="0"
                               Width="150" Height="450"
                               Stretch="Uniform"
                               IsHitTestVisible="False"/>
                    </Canvas>
                </Border>
            </Grid>
        </ScrollViewer>

    </Grid>
</UserControl>
