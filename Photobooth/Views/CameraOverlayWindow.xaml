<Window x:Class="Photobooth.Views.CameraOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Camera Dev Overlay"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Border Background="#CC050B12" CornerRadius="8" Padding="14,10"
            MouseDown="Window_MouseDown"
            Cursor="SizeAll">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.7" Color="Black"/>
        </Border.Effect>
        <StackPanel MinWidth="200">

            <!-- Header -->
            <Grid Margin="0,0,0,8" Cursor="SizeAll">
                <TextBlock Text="&#x25CF;  CAM DEV" Foreground="#3D7AB5"
                           FontSize="10" FontWeight="Bold" FontFamily="Consolas"
                           VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right" Click="Close_Click" Cursor="Hand" Focusable="False">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock x:Name="X" Text="&#x2715;" Foreground="#3D7AB5"
                                                   FontSize="10" FontFamily="Consolas"/>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="X" Property="Foreground" Value="#AACCFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <Rectangle Height="1" Fill="#1A2B44" Margin="0,0,0,8"/>

            <!-- Property rows -->
            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="ISO" Foreground="#2E5070" FontSize="11" FontFamily="Consolas"/>
                <TextBlock x:Name="IsoText" Grid.Column="1" Foreground="#C8E4FF" FontSize="11" FontFamily="Consolas" Text="&#x2014;"/>
            </Grid>

            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Tv" Foreground="#2E5070" FontSize="11" FontFamily="Consolas"/>
                <TextBlock x:Name="TvText" Grid.Column="1" Foreground="#C8E4FF" FontSize="11" FontFamily="Consolas" Text="&#x2014;"/>
            </Grid>

            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Av" Foreground="#2E5070" FontSize="11" FontFamily="Consolas"/>
                <TextBlock x:Name="AvText" Grid.Column="1" Foreground="#C8E4FF" FontSize="11" FontFamily="Consolas" Text="&#x2014;"/>
            </Grid>

            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="WB" Foreground="#2E5070" FontSize="11" FontFamily="Consolas"/>
                <TextBlock x:Name="WbText" Grid.Column="1" Foreground="#C8E4FF" FontSize="11" FontFamily="Consolas" Text="&#x2014;"/>
            </Grid>

            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Quality" Foreground="#2E5070" FontSize="11" FontFamily="Consolas"/>
                <TextBlock x:Name="IqText" Grid.Column="1" Foreground="#C8E4FF" FontSize="11" FontFamily="Consolas" Text="&#x2014;" TextWrapping="Wrap"/>
            </Grid>

            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Metering" Foreground="#2E5070" FontSize="11" FontFamily="Consolas"/>
                <TextBlock x:Name="MeteringText" Grid.Column="1" Foreground="#C8E4FF" FontSize="11" FontFamily="Consolas" Text="&#x2014;"/>
            </Grid>

        </StackPanel>
    </Border>
</Window>
