<Window x:Class="Photobooth.Views.NewEventDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Event"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        KeyDown="Window_KeyDown">
    <StackPanel Margin="28,24,28,24">

        <TextBlock Text="Event name"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="NameBox"
                 Background="{DynamicResource NavBrush}"
                 Foreground="White" BorderBrush="#334"
                 Padding="10,7" FontSize="13"
                 MaxLength="200"
                 Margin="0,0,0,6"/>
        <TextBlock x:Name="ErrorLabel"
                   Text="Name is required."
                   Foreground="#E05555"
                   FontSize="12"
                   Visibility="Collapsed"
                   Margin="0,0,0,12"/>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource GhostButton}"
                    Padding="18,7" FontSize="13"
                    Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button Content="Create"
                    Style="{StaticResource KioskButton}"
                    Padding="18,7" FontSize="13"
                    Click="Create_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
