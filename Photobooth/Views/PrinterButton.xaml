<UserControl x:Class="Photobooth.Views.PrinterButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Cursor="Hand">

    <!--
        All named elements live in the UserControl's own namescope — no ControlTemplate.
        Animation and interaction state are driven from code-behind.
    -->
    <Grid MouseLeftButtonDown="Root_MouseLeftButtonDown"
          MouseLeftButtonUp="Root_MouseLeftButtonUp"
          MouseEnter="Root_MouseEnter"
          MouseLeave="Root_MouseLeave">

        <StackPanel HorizontalAlignment="Left">

            <!-- Paper feed slot on top -->
            <Border Width="30" Height="9"
                    HorizontalAlignment="Left" Margin="20,0,0,0"
                    Background="{DynamicResource NavBrush}"
                    CornerRadius="3,3,0,0"/>

            <!-- Printer body -->
            <Border x:Name="PrinterBody"
                    Width="88" Height="54"
                    Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="10">
                <Grid>
                    <!-- LED status dot -->
                    <Ellipse Width="7" Height="7"
                             Fill="{DynamicResource AccentBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Center"
                             Margin="0,0,13,0"/>
                    <!-- Output slot -->
                    <Border Height="4" Width="42"
                            VerticalAlignment="Bottom" HorizontalAlignment="Center"
                            Margin="0,0,0,11"
                            Background="{DynamicResource NavBrush}"
                            CornerRadius="2"/>
                </Grid>
            </Border>

            <!-- Clip zone: PaperStrip slides down into view from Y=-68 -->
            <Border Width="42" Height="68"
                    HorizontalAlignment="Left" Margin="23,0,0,0"
                    ClipToBounds="True" Background="Transparent">
                <Border x:Name="PaperStrip"
                        Width="38" Height="68"
                        Background="White" CornerRadius="0,0,4,4"
                        VerticalAlignment="Top" HorizontalAlignment="Center">
                    <Border.RenderTransform>
                        <TranslateTransform Y="-68"/>
                    </Border.RenderTransform>
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="3" BlurRadius="6"
                                          Direction="270" Opacity="0.35"/>
                    </Border.Effect>
                    <StackPanel Margin="5,6,5,5">
                        <Rectangle Height="15" RadiusX="1" RadiusY="1" Fill="#DDDDDD" Margin="0,0,0,4"/>
                        <Rectangle Height="15" RadiusX="1" RadiusY="1" Fill="#E8E8E8" Margin="0,0,0,4"/>
                        <Rectangle Height="15" RadiusX="1" RadiusY="1" Fill="#D8D8D8"/>
                    </StackPanel>
                </Border>
            </Border>

        </StackPanel>
    </Grid>
</UserControl>
