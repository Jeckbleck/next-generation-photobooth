<UserControl x:Class="Photobooth.Views.DisplayPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Larger touch target than the app-wide Slider style, for this panel only -->
        <Style TargetType="Slider">
            <Setter Property="Cursor"               Value="Hand"/>
            <Setter Property="FocusVisualStyle"     Value="{x:Null}"/>
            <Setter Property="IsSnapToTickEnabled"  Value="True"/>
            <Setter Property="TickFrequency"        Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="44" VerticalAlignment="Center">
                            <!-- Unfilled track -->
                            <Border Height="10" CornerRadius="5" Background="#1E2F4A"
                                    VerticalAlignment="Center"/>
                            <!-- Track handles fill + thumb positioning -->
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Focusable="False" IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="10" CornerRadius="5"
                                                        Background="{DynamicResource AccentBrush}"
                                                        VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb FocusVisualStyle="{x:Null}">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="ThumbDot"
                                                         Width="40" Height="40"
                                                         Fill="{DynamicResource AccentBrush}"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbDot" Property="Fill"
                                                                Value="{DynamicResource AccentHoverBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbDot" Property="Fill"
                                                                Value="{DynamicResource AccentPressedBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Focusable="False" IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <StackPanel>
        <TextBlock Text="Display" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" FontWeight="Bold" Margin="0,0,0,20"/>

        <ContentControl x:Name="AppearancePanelHost"/>

        <TextBlock Text="GREETING TEXT" Foreground="{DynamicResource AccentBrush}"
                   FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock Text="Applies to the active event. Leave blank for the default." Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,10"/>
        <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

        <TextBlock Text="Eyebrow line" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="GreetingEyebrowBox"
                 Background="{DynamicResource NavBrush}" Foreground="White" BorderBrush="#334"
                 Padding="10,7" FontSize="13" Margin="0,0,0,8"
                 TextChanged="GreetingBox_TextChanged"/>

        <TextBlock Text="Main title" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="GreetingTitleBox"
                 Background="{DynamicResource NavBrush}" Foreground="White" BorderBrush="#334"
                 Padding="10,7" FontSize="13" Margin="0,0,0,8"
                 TextChanged="GreetingBox_TextChanged"/>

        <TextBlock Text="Subtitle" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="GreetingSubtitleBox"
                 Background="{DynamicResource NavBrush}" Foreground="White" BorderBrush="#334"
                 Padding="10,7" FontSize="13" Margin="0,0,0,20"
                 TextWrapping="Wrap"
                 TextChanged="GreetingBox_TextChanged"/>

        <TextBlock Text="COUNTDOWN" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
        <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/><ColumnDefinition Width="36"/></Grid.ColumnDefinitions>
            <TextBlock Text="Countdown" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
            <Slider x:Name="CountdownSlider" Grid.Column="1" Minimum="3" Maximum="10" Value="3" ValueChanged="CountdownSlider_ValueChanged" ScrollViewer.PanningMode="None"/>
            <TextBlock Grid.Column="2"
                       Text="{Binding Value, ElementName=CountdownSlider, StringFormat='{}{0:0} s'}"
                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" VerticalAlignment="Center" Margin="6,0,0,0"/>
        </Grid>

        <TextBlock Text="SESSION" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
        <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/><ColumnDefinition Width="36"/></Grid.ColumnDefinitions>
            <TextBlock Text="Preview hold" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
            <Slider x:Name="PreviewHoldSlider" Grid.Column="1" Minimum="1" Maximum="60" Value="5" ValueChanged="PreviewHoldSlider_ValueChanged" ScrollViewer.PanningMode="None"/>
            <TextBlock Grid.Column="2"
                       Text="{Binding Value, ElementName=PreviewHoldSlider, StringFormat='{}{0:0} s'}"
                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" VerticalAlignment="Center" Margin="6,0,0,0"/>
        </Grid>
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/><ColumnDefinition Width="36"/></Grid.ColumnDefinitions>
            <TextBlock Text="Retake window" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
            <Slider x:Name="RetakeHoldSlider" Grid.Column="1" Minimum="2" Maximum="10" Value="3" ValueChanged="RetakeHoldSlider_ValueChanged" ScrollViewer.PanningMode="None"/>
            <TextBlock Grid.Column="2"
                       Text="{Binding Value, ElementName=RetakeHoldSlider, StringFormat='{}{0:0} s'}"
                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" VerticalAlignment="Center" Margin="6,0,0,0"/>
        </Grid>
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/><ColumnDefinition Width="36"/></Grid.ColumnDefinitions>
            <TextBlock Text="Max retakes" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
            <Slider x:Name="MaxRetakesSlider" Grid.Column="1" Minimum="0" Maximum="10" Value="3" ValueChanged="MaxRetakesSlider_ValueChanged" ScrollViewer.PanningMode="None"/>
            <TextBlock x:Name="MaxRetakesLabel" Grid.Column="2"
                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" VerticalAlignment="Center" Margin="6,0,0,0"/>
        </Grid>
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="Idle return" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" Padding="8,6">
                <ComboBoxItem Content="15 seconds"/>
                <ComboBoxItem Content="30 seconds" IsSelected="True"/>
                <ComboBoxItem Content="60 seconds"/>
                <ComboBoxItem Content="Never"/>
            </ComboBox>
        </Grid>

        <TextBlock Text="FEATURES" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
        <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Show attract screen when idle"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="13" VerticalAlignment="Center"/>
            <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
        </Grid>
        <Grid Margin="0,4,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Experimental features"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="13" VerticalAlignment="Center"/>
            <ToggleButton x:Name="ExperimentalFeaturesToggle" Grid.Column="1"
                          Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"
                          Checked="ExperimentalFeaturesToggle_Changed"
                          Unchecked="ExperimentalFeaturesToggle_Changed"/>
        </Grid>
    </StackPanel>
</UserControl>
