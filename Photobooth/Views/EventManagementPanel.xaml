<UserControl x:Class="Photobooth.Views.EventManagementPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="StepperButton" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#141F2E" CornerRadius="4"
                                BorderBrush="#334" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A2B44"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <TextBlock Text="Event Management" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" FontWeight="Bold" Margin="0,0,0,20"/>

        <TextBlock Text="ACTIVE EVENT" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
        <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

        <TextBlock Text="Select event" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="EventsComboBox"
                      Padding="8,6"
                      SelectionChanged="EventsComboBox_SelectionChanged"/>
            <Button x:Name="NewEventButton" Grid.Column="1"
                    Width="26" Height="26" Padding="0" Cursor="Hand"
                    ToolTip="New event" Margin="8,0,0,0"
                    Click="NewEvent_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#141F2E" CornerRadius="4"
                                BorderBrush="#334" BorderThickness="1" Width="26" Height="26">
                            <TextBlock Text="+" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="16" FontWeight="Light"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Bd" Property="Background" Value="#1A2B44"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button x:Name="BrowseEventsButton" Grid.Column="2"
                    Width="26" Height="26" Padding="0" Cursor="Hand"
                    ToolTip="Browse all events" Margin="6,0,0,0"
                    Click="BrowseEvents_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#141F2E" CornerRadius="4"
                                BorderBrush="#334" BorderThickness="1" Width="26" Height="26">
                            <TextBlock Text="&#x229E;" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Bd" Property="Background" Value="#1A2B44"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <Button x:Name="ArchiveEventButton"
                Content="Archive event"
                Style="{StaticResource GhostButton}"
                HorizontalAlignment="Left"
                Padding="18,7" FontSize="13"
                IsEnabled="False"
                Margin="0,0,0,8"
                Click="ArchiveEvent_Click"/>
        <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,20"/>

        <TextBlock Text="EVENT OPTIONS" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
        <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Paid event" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                <TextBlock Text="Require payment before each session" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
            <ToggleButton x:Name="PaywallToggle" Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="False" VerticalAlignment="Center" Click="Toggle_Click"/>
        </Grid>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Save images" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                <TextBlock Text="Store photos to disk after each session" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
            <ToggleButton x:Name="SaveImagesToggle" Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Click="Toggle_Click"/>
        </Grid>

        <TextBlock Text="Print limit per event" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,4"/>
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="PrintLimitMinus" Grid.Column="0"
                    Style="{StaticResource StepperButton}" Content="−"
                    Margin="0,0,4,0"
                    Click="PrintLimitMinus_Click"/>
            <TextBox x:Name="PrintLimitBox"
                     Grid.Column="1"
                     Background="{DynamicResource NavBrush}" Foreground="White" BorderBrush="#334"
                     Padding="10,7" FontSize="13" VerticalContentAlignment="Center" TextAlignment="Center"
                     PreviewTextInput="PrintLimitBox_PreviewTextInput"
                     LostFocus="PrintLimitBox_LostFocus"/>
            <Button x:Name="PrintLimitPlus" Grid.Column="2"
                    Style="{StaticResource StepperButton}" Content="+"
                    Margin="4,0,0,0"
                    Click="PrintLimitPlus_Click"/>
            <TextBlock Grid.Column="3" Text="total prints max" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
        </Grid>

        <TextBlock Text="Print limit per session" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="SessionLimitMinus" Grid.Column="0"
                    Style="{StaticResource StepperButton}" Content="−"
                    Margin="0,0,4,0"
                    Click="SessionLimitMinus_Click"/>
            <TextBox x:Name="SessionLimitBox"
                     Grid.Column="1"
                     Background="{DynamicResource NavBrush}" Foreground="White" BorderBrush="#334"
                     Padding="10,7" FontSize="13" VerticalContentAlignment="Center" TextAlignment="Center"
                     PreviewTextInput="SessionLimitBox_PreviewTextInput"
                     LostFocus="SessionLimitBox_LostFocus"/>
            <Button x:Name="SessionLimitPlus" Grid.Column="2"
                    Style="{StaticResource StepperButton}" Content="+"
                    Margin="4,0,0,0"
                    Click="SessionLimitPlus_Click"/>
            <TextBlock Grid.Column="3" Text="prints per session" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
        </Grid>

        <TextBlock Text="STORAGE" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
        <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,14"/>

        <TextBlock Text="Save photos to" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="StoragePathBox"
                     Background="{DynamicResource NavBrush}" Foreground="White" BorderBrush="#334"
                     Padding="10,7" FontSize="12" IsReadOnly="True"
                     VerticalContentAlignment="Center"/>
            <Button Grid.Column="1" Content="Browse"
                    Style="{StaticResource GhostButton}"
                    Padding="14,6" FontSize="13" Margin="8,0,0,0"
                    Click="BrowseStoragePath_Click"/>
        </Grid>
        <TextBlock x:Name="StoragePathWarning"
                   Text="⚠  No storage path set — events cannot be created until a folder is selected."
                   Foreground="#E9A020" FontSize="12" TextWrapping="Wrap"
                   Visibility="Collapsed" Margin="0,0,0,14"/>
        <Rectangle Height="1" Fill="#1E2F4A" Margin="0,14,0,14"/>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="SESSION PREVIEW" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button x:Name="OpenSessionBrowserButton" Grid.Column="1"
                    Width="26" Height="26" Padding="0" Cursor="Hand"
                    ToolTip="View all sessions"
                    Click="OpenSessionBrowser_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PlusBorder"
                                Background="#141F2E" CornerRadius="4"
                                BorderBrush="#334" BorderThickness="1"
                                Width="26" Height="26">
                            <TextBlock Text="+" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="16" FontWeight="Light"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PlusBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="PlusBorder" Property="Background" Value="#1A2B44"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
        <Rectangle Height="1" Fill="#1E2F4A" Margin="0,0,0,12"/>

        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,8">
            <ItemsControl x:Name="SessionPreviewList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Cursor="Hand" Padding="0" BorderThickness="0"
                                Background="Transparent"
                                Click="SessionPreviewCard_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CardBorder"
                                            Background="{DynamicResource NavBrush}" CornerRadius="6"
                                            Margin="0,0,8,4" BorderBrush="#1E2F4A"
                                            BorderThickness="1" Width="110" Padding="8,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Date}"
                                                       Foreground="#777799" FontSize="10"
                                                       Margin="0,0,0,6"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <ItemsControl ItemsSource="{Binding Thumbnails}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="3" ClipToBounds="True" Margin="0,0,3,0">
                                                            <Image Source="{Binding}" Width="28" Height="20"
                                                                   Stretch="UniformToFill"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            <Setter TargetName="CardBorder" Property="Background" Value="#111D30"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </StackPanel>
</UserControl>
